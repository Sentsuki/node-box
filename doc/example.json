{
  "nodes": {
    "subscriptions": [
      {
        "name": "clash_subscription_1",
        "url": "https://example.com/clash/subscription1",
        "type": "clash",
        "enable": true,
        "user_agent": "Custom-User-Agent/1.0"
      },
      {
        "name": "singbox_subscription_1",
        "url": "https://example.com/singbox/subscription1",
        "type": "singbox",
        "enable": true
      },
      {
        "name": "local_clash_config",
        "path": "/path/to/local/clash/config.yaml",
        "type": "clash",
        "enable": true
      },
      {
        "name": "relay_subscription",
        "url": "https://example.com/relay/subscription",
        "type": "relay",
        "enable": false
      }
    ],
    "targets": [
      {
        "name": "main_config_directory",
        "path": "/path/to/config/directory",
        "is_file": false,
        "subscriptions": [
          "clash_subscription_1",
          "singbox_subscription_1"
        ],
        "proxies": [
          {
            "insert_marker": "# PROXY_NODES",
            "include_keywords": [
              "香港",
              "新加坡",
              "美国"
            ],
            "exclude_keywords": [
              "过期",
              "测试"
            ],
            "relay_nodes": [
              "relay-hk-01",
              "relay-sg-01"
            ]
          },
          {
            "insert_marker": "# STREAMING_NODES",
            "include_keywords": [
              "Netflix",
              "Disney",
              "流媒体"
            ],
            "exclude_keywords": [
              "限速"
            ]
          }
        ]
      },
      {
        "name": "single_config_file",
        "path": "/path/to/specific/config.json",
        "is_file": true,
        "proxies": [
          {
            "insert_marker": "# ALL_NODES",
            "relay_nodes": [
              "backup-relay"
            ]
          }
        ]
      }
    ],
    "exclude_keywords": [
      "过期",
      "失效",
      "测试"
    ],
    "include_relay": [
      {
        "tag": "relay-premium",
        "upstream": [
          "premium",
          "vip",
          "高级"
        ]
      },
      {
        "tag": "relay-backup",
        "upstream": [
          "backup",
          "备用"
        ]
      }
    ]
  },
  "modules": {
    "log": [
      {
        "name": "default_log",
        "path": "/path/to/local/log.json"
      },
      {
        "name": "remote_log",
        "from_url": "https://example.com/modules/log.json"
      }
    ],
    "dns": [
      {
        "name": "cloudflare_dns",
        "from_url": "https://example.com/modules/dns/cloudflare.json"
      },
      {
        "name": "local_dns",
        "path": "/path/to/local/dns.json"
      }
    ],
    "ntp": [
      {
        "name": "system_ntp",
        "path": "/path/to/ntp.json"
      }
    ],
    "certificate": [
      {
        "name": "ca_bundle",
        "from_url": "https://example.com/modules/ca-bundle.json"
      }
    ],
    "endpoints": [
      {
        "name": "api_endpoints",
        "path": "/path/to/endpoints.json"
      }
    ],
    "inbounds": [
      {
        "name": "http_inbound",
        "from_url": "https://example.com/modules/inbounds/http.json"
      },
      {
        "name": "socks_inbound",
        "path": "/path/to/socks_inbound.json"
      }
    ],
    "outbounds": [
      {
        "name": "direct_outbound",
        "path": "/path/to/direct.json"
      },
      {
        "name": "block_outbound",
        "from_url": "https://example.com/modules/outbounds/block.json"
      }
    ],
    "route": [
      {
        "name": "china_route",
        "from_url": "https://example.com/modules/routes/china.json"
      },
      {
        "name": "custom_route",
        "path": "/path/to/custom_route.json"
      }
    ],
    "services": [
      {
        "name": "clash_api",
        "path": "/path/to/clash_api.json"
      }
    ],
    "experimental": [
      {
        "name": "new_feature",
        "from_url": "https://example.com/modules/experimental/feature.json"
      }
    ]
  },
  "configs": [
    {
      "name": "main_config",
      "path": "/path/to/main/config.json",
      "modules": [
        "default_log",
        "cloudflare_dns",
        "direct_outbound",
        "china_route"
      ],
      "no_need": [
        "测试",
        "过期",
        "失效"
      ]
    },
    {
      "name": "streaming_config",
      "path": "/path/to/streaming/config.json",
      "modules": [
        "remote_log",
        "local_dns",
        "http_inbound",
        "custom_route"
      ],
      "no_need": [
        "广告",
        "限速",
        "临时"
      ]
    }
  ],
  "update_interval_hours": 24,
  "log_level": "info",
  "proxy": {
    "type": "http",
    "host": "proxy.example.com",
    "port": 8080,
    "username": "proxy_user",
    "password": "proxy_password"
  },
  "user_agent": "NodeBox/1.0 (Custom User Agent)"
}